{
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash", "hooks": [ { "type": "command", "command": "/ABSOLUTE/PATH/TO/uconsole-buddy/bridge/bridge/hooks/pretooluse.py", "timeout": 120 } ] }
    ],
    "PostToolUse": [
      { "matcher": "*", "hooks": [ { "type": "command", "command": "/ABSOLUTE/PATH/TO/uconsole-buddy/bridge/bridge/hooks/posttooluse.py", "timeout": 10 } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "/ABSOLUTE/PATH/TO/uconsole-buddy/bridge/bridge/hooks/userprompt.py", "timeout": 10 } ] }
    ],
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "/ABSOLUTE/PATH/TO/uconsole-buddy/bridge/bridge/hooks/session.py", "timeout": 10 } ] }
    ],
    "Notification": [
      { "hooks": [ { "type": "command", "command": "/ABSOLUTE/PATH/TO/uconsole-buddy/bridge/bridge/hooks/notify.py", "timeout": 10 } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "/ABSOLUTE/PATH/TO/uconsole-buddy/bridge/bridge/hooks/stop.py", "timeout": 10 } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "/ABSOLUTE/PATH/TO/uconsole-buddy/bridge/bridge/hooks/sessionend.py", "timeout": 10 } ] }
    ]
  }
}
